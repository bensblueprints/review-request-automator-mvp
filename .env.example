# Askback configuration — copy to .env and edit

# Port the web app listens on
PORT=5362

# Admin password for the dashboard (change this!)
ADMIN_PASSWORD=change-me

# SQLite database location
DB_PATH=./data/askback.db

# Public base URL of this install — used to build the "how was it?" links you
# send to customers, e.g. https://reviews.yourbusiness.com
BASE_URL=

# Your business name (merge field {{business}}) and the Google review page
# customers land on after a 4-5 star rating. Both are also editable in Settings.
# Get your link: Google Business Profile → "Ask for reviews".
BUSINESS_NAME=
GOOGLE_REVIEW_URL=

# ── BYO Twilio (SMS review requests) — get these from console.twilio.com ─────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ── BYO SMTP (email review requests, optional) ───────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Dry run: 1 = full pipeline runs (requests rendered, queued and logged) but
# NO real SMS/email is ever sent. Great for testing templates and routing.
DRY_RUN=

# Days to wait before a follow-up reminder when a customer hasn't responded
# (also editable in Settings). 0 disables follow-ups.
FOLLOWUP_DAYS=3

# Scheduler loop interval in ms (default 30000).
SCHED_INTERVAL_MS=30000
